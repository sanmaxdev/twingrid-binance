# TWIN GRID Console — Production Caddy Config
#
# Set your domain(s) via the SITE_DOMAIN environment variable, e.g.
#   SITE_DOMAIN="example.com, www.example.com"
# Defaults to :80 (plain HTTP) for local use if SITE_DOMAIN is unset.
#
# TLS: `tls internal` issues a self-signed cert (works behind Cloudflare "Full"
# mode or another terminating proxy). Remove that line to let Caddy obtain a
# public Let's Encrypt cert automatically for a real domain.

{$SITE_DOMAIN::80} {

    # Self-signed cert — works behind Cloudflare "Full" mode or another proxy.
    # Comment this out to use automatic Let's Encrypt certificates instead.
    tls internal

    # Request body size limit
    request_body {
        max_size 10MB
    }

    # WebSocket upgrade (must be before the /api/* catch-all)
    handle /api/v1/ws {
        reverse_proxy backend:8000
    }

    # API backend
    handle /api/* {
        reverse_proxy backend:8000 {
            transport http {
                read_timeout 300s
                write_timeout 300s
            }
        }
    }

    # Frontend (Next.js) — catch-all
    handle /* {
        reverse_proxy frontend:3000
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}
