# === Core ===
APP_ENV=development                # development | staging | production
APP_DEBUG=true
APP_PORT=8000
APP_PUBLIC_URL=http://localhost    # used in email links
APP_NAME="TWIN GRID Console"

# === Database (LOCAL POSTGRES) ===
POSTGRES_PASSWORD=change_me_to_strong_random_password
DATABASE_URL=postgresql+asyncpg://app:change_me_to_strong_random_password@db:5432/twin_grid
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Security ===
JWT_SECRET=replace_with_64_byte_random_string_min
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
MASTER_ENCRYPTION_KEY=             # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PASSWORD_MIN_LENGTH=12
BCRYPT_COST=12

# === Bootstrap Super-Admin (used only on first start) ===
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=    # leave blank to be prompted

# === Signup ===
SIGNUP_ENABLED=true                # set false to disable public signup
EMAIL_VERIFICATION_REQUIRED=true

# === CORS (extra allowed origins, comma-separated) ===
# FRONTEND_URL and APP_PUBLIC_URL are always allowed. Add others here.
CORS_ORIGINS=

# === Email (SMTP) ===
SMTP_HOST=mailpit                  # MailHog/Mailpit in dev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="TWIN GRID Console"
SMTP_USE_TLS=false                 # true in production with real SMTP
EMAIL_FROM="Twin Grid <noreply@example.com>"

# === Binance ===
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
BINANCE_LIVE_BASE_URL=https://fapi.binance.com
BINANCE_TESTNET_WS_URL=wss://stream.binancefuture.com
BINANCE_LIVE_WS_URL=wss://fstream.binance.com

# === Frontend ===
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost/ws
NEXT_PUBLIC_APP_NAME="TWIN GRID Console"
NEXT_PUBLIC_SIGNUP_ENABLED=true
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # used for SEO metadata, sitemap, robots
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# === Reverse proxy (Caddy) ===
# Domain(s) Caddy serves. Leave unset for plain HTTP on :80 in local/dev.
# Example: SITE_DOMAIN="example.com, www.example.com"
SITE_DOMAIN=

# === Notifications (P1) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# === Observability ===
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=false
SENTRY_DSN=

# === Rate limits (overrides; defaults in code) ===
RATELIMIT_LOGIN_PER_IP=5/15m
RATELIMIT_REGISTER_PER_IP=3/1h
